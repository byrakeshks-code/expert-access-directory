# =========================
# Supabase
# =========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# =========================
# Redis
# =========================
# When using this project's docker-compose Redis, use port 6380 and password redis_dev_secret
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_dev_secret

# =========================
# Meilisearch
# =========================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key

# =========================
# Payments
# =========================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# =========================
# App
# =========================
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# =========================
# Email (Gmail SMTP for signup OTP)
# =========================
# Use Gmail app password (not account password): Google Account → Security → 2-Step Verification → App passwords
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your-gmail@gmail.com
EMAIL_SMTP_APP_PASSWORD=your-16-char-app-password
EMAIL_FROM=noreply@yourdomain.com
